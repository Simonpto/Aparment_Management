# Copy this file to .env and fill in your values
# Never commit .env to git

# Supabase PostgreSQL connection string
# Get from: Supabase dashboard → Project Settings → Database → Connection string (URI)
ConnectionStrings__Supabase=Host=db.<YOUR-PROJECT-REF>.supabase.co;Database=postgres;Username=postgres;Password=<YOUR-DB-PASSWORD>;SSL Mode=Require;Trust Server Certificate=true

# Admin password for the /api/admin/login endpoint
Admin__Password=change-me

# Supabase project URL and service role key (for Storage image uploads)
# Get from: Supabase dashboard → Project Settings → API
Supabase__Url=https://<YOUR-PROJECT-REF>.supabase.co
Supabase__ServiceKey=<YOUR-SERVICE-ROLE-KEY>
